Options -Indexes

# Fallback for servers that return 404 before mod_rewrite fires
ErrorDocument 404 /index.html

RewriteEngine On
RewriteBase /

# Pass /api/ requests through to PHP — do NOT rewrite to index.html
RewriteCond %{REQUEST_URI} ^/api/ [NC]
RewriteRule ^ - [L]

# Let real files and directories pass through
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d

# Everything else → index.html (SPA client-side routing)
RewriteRule . /index.html [L]

# Security headers
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set Referrer-Policy "no-referrer"
    Header always set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src https://fonts.gstatic.com; connect-src 'self' https://questlinecli.com https://webapp.questlinecli.com; img-src 'self' data:"
</IfModule>
